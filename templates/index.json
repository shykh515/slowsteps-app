    "reviews_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"gs-reviews-section\"><div class=\"page-width\"><div class=\"gs-reviews-header\"><p class=\"gs-reviews-label\">TESTIMONIALS<\/p><h2 class=\"gs-reviews-title\">What our customers say<\/h2><div class=\"gs-reviews-overall\"><span class=\"gs-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;<\/span><span class=\"gs-reviews-count\">4.9\/5 based on 200+ reviews<\/span><\/div><\/div><div class=\"gs-reviews-grid\"><div class=\"gs-review-card\"><div class=\"gs-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;<\/div><p class=\"gs-review-text\">&ldquo;Amazing quality bag! Exactly as shown in photos. Delivery was fast and packaging was beautiful. Will definitely order again from GlowSteps!&rdquo;<\/p><div class=\"gs-reviewer\"><strong>Aisha K.<\/strong><span>Karachi<\/span><\/div><\/div><div class=\"gs-review-card\"><div class=\"gs-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;<\/div><p class=\"gs-review-text\">&ldquo;Ordered the shoulder bag and I am absolutely in love. The leather quality is premium and the gold hardware looks so elegant. Highly recommended!&rdquo;<\/p><div class=\"gs-reviewer\"><strong>Fatima R.<\/strong><span>Lahore<\/span><\/div><\/div><div class=\"gs-review-card\"><div class=\"gs-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;<\/div><p class=\"gs-review-text\">&ldquo;Best online shopping experience in Pakistan! GlowSteps delivers on time and the bags are even better in person. The COD option makes it so easy.&rdquo;<\/p><div class=\"gs-reviewer\"><strong>Sana M.<\/strong><span>Islamabad<\/span><\/div><\/div><div class=\"gs-review-card\"><div class=\"gs-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;<\/div><p class=\"gs-review-text\">&ldquo;The stiletto heels I ordered are perfect! Comfortable and stylish. My friends keep asking where I got them. GlowSteps is my new favourite store!&rdquo;<\/p><div class=\"gs-reviewer\"><strong>Nadia A.<\/strong><span>Karachi<\/span><\/div><\/div><\/div><\/div><\/div>",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
